# Trading Bot Configuration
# Copy this to .env and fill in values

# Database (SQLite for local, PostgreSQL for production)
DATABASE_URL=sqlite:///./tradingbot.db
# DATABASE_URL=postgresql://user:pass@localhost/tradingbot

# Simulation settings
SIMULATION_MODE=true
INITIAL_BANKROLL=10000
KELLY_FRACTION=0.25
MIN_EDGE_THRESHOLD=0.08

# Kalshi API (RSA key auth for weather markets)
KALSHI_API_KEY_ID=KALSHI...
KALSHI_PRIVATE_KEY_PATH=/path/to/key.pem
KALSHI_ENABLED=true

# Ollama AI (OpenAI-compatible endpoint)
# For cloud models via Ollama subscription, leave OLLAMA_API_KEY empty
# or set it if your Ollama instance requires auth
OLLAMA_BASE_URL=http://localhost:11434/v1
OLLAMA_ANALYSIS_MODEL=glm-5.1:cloud
OLLAMA_CLASSIFY_MODEL=minimax-m2.7:cloud
OLLAMA_API_KEY=

# Backward compat (Groq keys, if needed)
GROQ_API_KEY=

# AI Feature Flags
AI_LOG_ALL_CALLS=true
AI_DAILY_BUDGET_USD=1.0